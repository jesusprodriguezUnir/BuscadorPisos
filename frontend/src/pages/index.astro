---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Filters from '../components/Filters.astro';
import PropertyCard from '../components/PropertyCard.astro';
import { supabase } from '../lib/supabase';

// Obtener propiedades activas y su historial de precios (ordenado del más nuevo al más antiguo)
const { data: properties, error } = await supabase
  .from('properties')
  .select(`
    *,
    price_history (
      price,
      date_recorded
    )
  `)
  .eq('status', 'active')
  .order('last_seen', { ascending: false });

if (error) {
  console.error('Error fetching properties:', error);
}
---

<Layout title="Inicio">
  <Hero />
  
  <div id="propiedades">
    <div class="flex items-center justify-between mb-6 px-2">
      <h2 class="text-2xl font-bold text-slate-800 tracking-tight">
        Últimas Oportunidades 
        <span class="ml-3 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-800">
          Encontradas Hoy
        </span>
      </h2>
      <a href="#" class="text-sm font-semibold text-blue-600 hover:text-blue-700 hover:underline underline-offset-4 hidden sm:block">
        Ver todas ({properties?.length || 0})
      </a>
    </div>

    <Filters />

    {error && (
      <div class="bg-red-50/80 backdrop-blur border border-red-200 p-6 rounded-2xl mb-8 flex gap-4 items-start shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-red-500 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
        <div>
          <h3 class="font-bold text-red-800 text-lg mb-1">Error al conectar con la base de datos</h3>
          <p class="text-red-700 font-medium">Revisa tus credenciales en el archivo .env o la consola del servidor.</p>
        </div>
      </div>
    )}

    {(!properties || properties.length === 0) && !error && (
      <div class="bg-white rounded-3xl border border-slate-100 p-12 text-center shadow-sm">
        <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-slate-50 mb-6 shadow-inner">
           <span class="text-5xl">🏠</span>
        </div>
        <h2 class="text-2xl font-bold text-slate-800 mb-3 tracking-tight">No hay propiedades rastreadas todavía</h2>
        <p class="text-slate-500 max-w-md mx-auto mb-8 font-medium">
          El radar está vacío por el momento. Ejecuta el scraper en segundo plano para empezar a recibir oportunidades del mercado inmobiliario en tiempo real.
        </p>
        <button class="bg-slate-900 hover:bg-slate-800 text-white px-6 py-3 rounded-full font-semibold transition-colors">
          Suscribirse a alertas
        </button>
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 lg:gap-8">
      {properties?.map((prop) => (
        <PropertyCard {...prop} />
      ))}
    </div>
  </div>
</Layout>
